{
  "name": "HomeWizard Instant Custom Component",
  "dockerComposeFile": "docker-compose.yml",
  "service": "homeassistant-dev",
  "runServices": ["homeassistant-dev", "dummy-p1"],
  "forwardPorts": [7123],
  "shutdownAction": "stopCompose",
  "postStartCommand": "python -m homeassistant -c /config",
  "workspaceFolder": "/workspaces/homeassistant-homewizard-instant",
  "containerEnv": {
    "WORKSPACE_DIRECTORY": "/workspaces/homeassistant-homewizard-instant"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnPaste": false,
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "files.trimTrailingWhitespace": true
      }
    }
  }
}